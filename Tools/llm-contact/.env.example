# Used by contact.js and run-suite.js to pick which API to call: anthropic
# (default) | openai | gemini | mistral | xai | deepseek. SITE and MODEL below
# are optional overrides — leave unset to use that provider's default
# endpoint/model (see client.js's PROVIDER_DEFAULTS).
PROVIDER=anthropic
# SITE=https://api.anthropic.com/v1/messages
# MODEL=claude-sonnet-5
ANTHROPIC_API_KEY=sk-ant-...
MAX_TOKENS=1024
# EFFORT=high  # low | medium | high | xhigh | max — leave unset for models without
             # effort/thinking support (e.g. Haiku); errors with a 400 otherwise.

# The rest of these are only required if PROVIDER selects that provider — any
# left unset are fine as long as PROVIDER doesn't need them (test-connections.js
# uses whichever of these are set and skips the rest rather than erroring).
OPENAI_API_KEY=sk-proj-...
GEMINI_API_KEY=...
MISTRAL_API_KEY=...
X_API_KEY=xai-...
DEEPSEEK_API_KEY=sk-...

# Used by contact.js (ad-hoc single-prompt tool)
LLM_PROMPT=Say hello and confirm you are working.

# Used by run-suite.js (Suites/Runs harness). The judge always runs on the
# same PROVIDER as the target; leave JUDGE_MODEL unset to judge with MODEL.
# JUDGE_MODEL=claude-sonnet-5
SUITE=LLM01-Prompt-Injection
