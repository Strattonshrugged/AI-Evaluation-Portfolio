SITE=https://api.anthropic.com/v1/messages
ANTHROPIC_API_KEY=sk-ant-...
MODEL=claude-sonnet-5
MAX_TOKENS=1024
# EFFORT=high  # low | medium | high | xhigh | max — leave unset for models without
             # effort/thinking support (e.g. Haiku); errors with a 400 otherwise.

# Used by contact.js (ad-hoc single-prompt tool)
LLM_PROMPT=Say hello and confirm you are working.

# Used by run-suite.js (Suites/Runs harness)
JUDGE_MODEL=claude-sonnet-5
SUITE=LLM01-Prompt-Injection
